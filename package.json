{
  "name": "antiscam-api",
  "version": "1.0.0",
  "description": "Express.js API with antiscam system information endpoints",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "generate-key": "node scripts/generate-api-key.js"
  },
  "keywords": [
    "express",
    "api",
    "antiscam",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/express": "^4.17.20",
    "@types/cors": "^2.8.16",
    "@types/node": "^20.8.9",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1"
  }
}
